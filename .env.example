# ── Required ──────────────────────────────────────────────────────────────────
# Public URL of the backend — used by the browser for SSE streaming
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Origins allowed by the backend CORS policy (comma-separated)
ALLOWED_ORIGINS=https://yourdomain.com

# Login credentials for the frontend
AUTH_USERNAME=Spiritory
AUTH_PASSWORD=change_me

# ── Optional ──────────────────────────────────────────────────────────────────
# Residential proxy to reduce Cloudflare bans (format: http://user:pass@ip:port)
# PROXY_URL=
